# Copy to .env.local and fill in.
# All values shown here are safe defaults for local dev.

# Random string used to sign session cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=change-me-to-a-random-32-plus-character-string

# Code required at signup to claim admin role.
ADMIN_CODE=letmein

# Optional: restrict driver signup to pre-approved emails (comma-separated).
# Leave blank to allow any driver signup.
# APPROVED_DRIVER_EMAILS=driver1@company.com,driver2@company.com

# Optional: if set, app uses Vercel Postgres instead of local JSON file.
# POSTGRES_URL=postgres://...

# Optional: used for logout redirect in production.
# NEXT_PUBLIC_BASE_URL=https://your-domain.vercel.app

# Optional: mobile app handoff after successful pre-shift inspection.
# Can be an https:// link or deep link URI (e.g. via://...).
# NEXT_PUBLIC_VIA_REDIRECT_URL=https://m.via.com

# Optional: phone shown for "Call dispatch" action on approved shifts.
# NEXT_PUBLIC_DISPATCH_PHONE=+1-757-555-0100

# Required to enable self-service password reset by phone.
# Share this code only through dispatch after identity verification.
DRIVER_PASSWORD_RESET_CODE=Reset
